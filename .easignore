# node_modules viene reinstallato da EAS Build tramite yarn install
node_modules

# Ignora cartelle native — EAS le rigenera via prebuild
android/
ios/

# Ignora file di cache
.git
.expo
.vscode
.idea

# Ignora file di test
__tests__
**/*.test.js
**/*.spec.js
**/*.spec.ts
**/*.spec.tsx
**/*.test.ts
**/*.test.tsx

# Ignora file di documentazione
docs
*.md
LICENSE
CHANGELOG*
CONTRIBUTING*

# Ignora file temporanei
*.log
*.tmp
.DS_Store
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignora file di configurazione di sviluppo
.eslintrc*
.prettierrc*
.babelrc*
jest.config.*
*.tsbuildinfo

# Ignora immagini e asset non necessari per la build
**/*.psd
**/*.ai
**/*.sketch
